{
  "display_information": {
    "name": "portfolio-analytics"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "assistant_view": {
      "assistant_description": "Answers analytics questions about the mobile app portfolio.",
      "suggested_prompts": [
        {
          "title": "Top countries",
          "message": "Which countries have the most installs this month?"
        },
        {
          "title": "Revenue definition",
          "message": "Which countries generate the most revenue?"
        }
      ]
    },
    "bot_user": {
      "display_name": "portfolio-analytics-assistant",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "assistant:write",
        "chat:write",
        "files:write",
        "im:history"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "assistant_thread_started",
        "assistant_thread_context_changed",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": true,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
